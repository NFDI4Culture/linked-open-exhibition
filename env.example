# .env.example — copy this file to .env and fill in your values
# The .env file is gitignored and must NEVER be committed to version control.
#
# Wikibase instance
WB_URL=https://wikibase.wbworkshop.tibwiki.io
# SPARQL query endpoint (may differ from the main Wikibase URL)
SPARQL_URL=https://query.wbworkshop.tibwiki.io/sparql

# Bot account credentials (created at Special:BotPasswords)
# Format: YourUsername@YourBotName
WB_USER=YourUsername@YourBotName
WB_PASSWORD=your-generated-bot-password

# MediaWiki credentials (can be the same bot account)
MW_URL=https://wikibase.wbworkshop.tibwiki.io
MW_USER=YourUsername@YourBotName
MW_PASSWORD=your-generated-bot-password
